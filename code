    return ch;
}

// --- LCD ---
#define LCD_ADDR (0x27 << 1) // Try (0x3F << 1) if it doesn't work

void I2C_Reset(void) {
    HAL_I2C_DeInit(&hi2c1);
    HAL_Delay(10);

    GPIO_InitTypeDef GPIO_InitStruct = {0};
    __HAL_RCC_GPIOB_CLK_ENABLE();
    GPIO_InitStruct.Pin = GPIO_PIN_6 | GPIO_PIN_7;
    GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_OD;
    GPIO_InitStruct.Pull = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
    HAL_GPIO_Init(GPIOB, &GPIO_InitStruct);

    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_7, GPIO_PIN_SET);
    for (int i = 0; i < 9; i++) {
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_6, GPIO_PIN_RESET);
        HAL_Delay(1);
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_6, GPIO_PIN_SET);
        HAL_Delay(1);
    }
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_7, GPIO_PIN_RESET);
    HAL_Delay(1);
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_7, GPIO_PIN_SET);
    HAL_Delay(1);

    MX_I2C1_Init();
    HAL_Delay(10);
}

void lcd_send_cmd(char cmd) {
    char data_u, data_l;
    uint8_t data_t[4];
    data_u = (cmd & 0xf0);
    data_l = ((cmd << 4) & 0xf0);
    data_t[0] = data_u | 0x0C;
    data_t[1] = data_u | 0x08;
    data_t[2] = data_l | 0x0C;
    data_t[3] = data_l | 0x08;
    if (HAL_I2C_Master_Transmit(&hi2c1, LCD_ADDR, (uint8_t *)data_t, 4, 500) != HAL_OK) {
        I2C_Reset();
    }
}

void lcd_send_data(char data) {
    char data_u, data_l;
    uint8_t data_t[4];
    data_u = (data & 0xf0);
    data_l = ((data << 4) & 0xf0);
    data_t[0] = data_u | 0x0D;
    data_t[1] = data_u | 0x09;
    data_t[2] = data_l | 0x0D;
    data_t[3] = data_l | 0x09;
    if (HAL_I2C_Master_Transmit(&hi2c1, LCD_ADDR, (uint8_t *)data_t, 4, 500) != HAL_OK) {
        I2C_Reset();
    }
}

void lcd_init(void) {
    HAL_Delay(50);
    lcd_send_cmd(0x30); HAL_Delay(5);
    lcd_send_cmd(0x30); HAL_Delay(1);
    lcd_send_cmd(0x30); HAL_Delay(1);
    lcd_send_cmd(0x20); HAL_Delay(1);
    lcd_send_cmd(0x28); HAL_Delay(1);
    lcd_send_cmd(0x08); HAL_Delay(1);
    lcd_send_cmd(0x01); HAL_Delay(2);
    lcd_send_cmd(0x06); HAL_Delay(1);
    lcd_send_cmd(0x0C); HAL_Delay(1);
}

void lcd_send_string(char *str) {
    while (*str) lcd_send_data(*str++);
}

void lcd_put_cur(int row, int col) {
    switch (row) {
        case 0: col |= 0x80; break;
        case 1: col |= 0xC0; break;
    }
    lcd_send_cmd(col);
}

void lcd_clear(void) {
    lcd_send_cmd(0x01);
    HAL_Delay(2);
}
// --- END OF LCD ---

int main(void) {
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_I2C1_Init();
    MX_TIM2_Init();
    MX_USART1_UART_Init();
    MX_USART2_UART_Init();

    uint8_t wake_data = 0x00;
    HAL_I2C_Mem_Write(&hi2c1, (0x68 << 1), 0x6B, 1, &wake_data, 1, 100);

    HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);

    lcd_init();
    lcd_clear();
    lcd_put_cur(0, 2);
    lcd_send_string("System Ready");
    HAL_Delay(1500);
    lcd_clear();

    while (1) {
        uint8_t rawData[6];
        int16_t accel_X, accel_Y, accel_Z;
        double roll_angle;
        int pwm_value = 0;
        int min_pwm = 250;

        HAL_I2C_Mem_Read(&hi2c1, (0x68 << 1), 0x3B, 1, rawData, 6, 100);
        accel_X = (int16_t)((rawData[0] << 8) | rawData[1]);
        accel_Y = (int16_t)((rawData[2] << 8) | rawData[3]);
        accel_Z = (int16_t)((rawData[4] << 8) | rawData[5]);

        roll_angle = atan2(accel_X, sqrt(pow(accel_Y, 2) + pow(accel_Z, 2))) * (180.0 / 3.14159);

        if (roll_angle > 10.0) {
            HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_SET);
            HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);
            pwm_value = min_pwm + (int)((roll_angle - 10.0) * ((1000.0 - min_pwm) / 80.0));
        } else if (roll_angle < -10.0) {
            HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET);
            HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_SET);
            pwm_value = min_pwm + (int)((fabs(roll_angle) - 10.0) * ((1000.0 - min_pwm) / 80.0));
        } else {
            HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET);
            HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);
            pwm_value = 0;
        }

        if (pwm_value > 1000) pwm_value = 1000;
        __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, pwm_value);

        printf("Angle: %.2f | PWM: %d\r\n", roll_angle, pwm_value);

        char lcd_buffer[32];
        lcd_put_cur(0, 0);
        sprintf(lcd_buffer, "Angle: %.2f     ", roll_angle);
        lcd_send_string(lcd_buffer);

        lcd_put_cur(1, 0);
        sprintf(lcd_buffer, "PWM: %d       ", pwm_value);
        lcd_send_string(lcd_buffer);

        HAL_Delay(200);
    }
}

